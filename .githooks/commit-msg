#!/bin/sh
# Validates commit messages against the Conventional Commits specification.
# See CONTRIBUTING.md for format details.

msg=$(head -1 "$1")
pattern='^(feat|fix|docs|refactor|test|chore|perf|ci|build)(\([a-z]+\))?: .{1,72}$'

if ! echo "$msg" | grep -qE "$pattern"; then
  echo ""
  echo "ERROR: Commit message does not follow Conventional Commits."
  echo ""
  echo "  Expected:  <type>(<scope>): <summary>"
  echo "  Got:       $msg"
  echo ""
  echo "  Types: feat fix docs refactor test chore perf ci build"
  echo "  Scope: optional — backend frontend shared config ci"
  echo ""
  echo "  Examples:"
  echo "    feat(backend): add thread pinning endpoint"
  echo "    fix(frontend): prevent XSS in markdown preview"
  echo "    docs: update API endpoint documentation"
  echo ""
  exit 1
fi
